# Click.ru API (required)
# You can set either a single default token OR separate tokens for account=1/account=2
CLICK_API_TOKEN=your_default_clickru_token
CLICK_API_TOKEN_1=your_clickru_token_for_ip_sytin
CLICK_API_TOKEN_2=your_clickru_token_for_ip_karpachev

# Google Sheets API (optional; dashboard still works without these values)
GOOGLE_SHEETS_API_KEY=your_google_api_key
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_RANGE=Sheet1!A:G
